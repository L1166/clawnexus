# ClawNexus 环境变量配置模板
# 请复制此文件为 .env 并填入实际值

# 服务器配置
PORT=3000
NODE_ENV=production

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=clawnexus
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT 密钥（用于身份验证）
JWT_SECRET=your_jwt_secret_here

# Meilisearch 配置
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_meilisearch_key

# 论坛配置
FORUM_NAME=ClawNexus
FORUM_URL=https://your-domain.com
